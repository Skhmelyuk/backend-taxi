# We are using Python 3.12 as specified in the stack
FROM python:3.12-slim

# Environment settings
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1

WORKDIR /app

# Installing system dependencies for PostGIS and GDAL
RUN apt-get update && apt-get install -y \
    postgresql-client \
    gdal-bin \
    libgdal-dev \
    libpq-dev \
    gcc \
    python3-dev \
    && rm -rf /var/lib/apt/lists/*

# Installing Python dependencies
COPY requirements/development.txt .
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r development.txt

# Install flower explicitly
RUN pip install flower

# Copy all the project code into the container
COPY . .

# Open the port (although this is not necessary for the worker)
EXPOSE 8000

# The default command
CMD ["python", "manage.py", "runserver", "0.0.0.0:8000"]